# --- GitHub OAuth (Phase 1 auth gate) ---
# From your GitHub OAuth App (Settings -> Developer settings -> OAuth Apps).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Public base URL of this Outpost instance; the OAuth callback URL is derived from it.
OUTPOST_BASE_URL=
# Comma-separated numeric GitHub user IDs allowed to log in (NOT usernames).
# Find yours at https://api.github.com/users/YOUR_USERNAME. Boot fails loud if empty.
OUTPOST_ALLOWED_GITHUB_IDS=

# --- Sandbox lifecycle (Phase 2, Fly.io) ---
# Fly API token with access to the sandbox app. Boot fails loud if unset.
FLY_API_TOKEN=
# Fly app that holds sandbox machines -- MUST be separate from the server's Fly app
# (per-app 6PN network isolation is the sandbox egress boundary).
FLY_SANDBOX_APP=
# Region for sandbox machines AND their volumes (Fly volumes are region-pinned;
# a mismatch causes a silent start failure).
FLY_REGION=
# Container image sandbox machines run,
# e.g. ghcr.io/useoutpost-dev/outpost-sandbox:cc-2.1.208
OUTPOST_SANDBOX_IMAGE=
# OTLP collector endpoint injected into each sandbox as OTEL_EXPORTER_OTLP_ENDPOINT.
OUTPOST_COLLECTOR_ENDPOINT=

# --- Server runtime (optional) ---
# HTTP port (default 3001).
PORT=
# SQLite database path (default ./outpost.db).
OUTPOST_DB_PATH=
# Set to 1 ONLY for local http dev to drop the Secure flag on session cookies.
# Never set in production.
OUTPOST_INSECURE_COOKIES=
